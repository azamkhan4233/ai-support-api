# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT Configuration
JWT_SECRET=your-secure-jwt-secret-key-at-least-32-characters-long

# Database Configuration (if not using Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ai_support_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Redis Configuration (if not using Docker)
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
