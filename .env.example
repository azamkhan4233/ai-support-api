# AI API (Groq OpenAI-compatible endpoint by default)
OPENAI_API_KEY=your-api-key-here
OPENAI_API_URL=https://api.groq.com/openai/v1/chat/completions
OPENAI_MODEL=llama-3.3-70b-versatile

# JWT Configuration
JWT_SECRET=your-secure-jwt-secret-key-at-least-32-characters-long

# Database Configuration (production / Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ai_support_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
