{
  "info": {
    "name": "AI Support API",
    "description": "Collection for testing AI Customer Support API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@techcorp.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Start Chat Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessId\": 1,\n  \"ipAddress\": \"192.168.1.1\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/chat/start",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "chat", "start"]
            }
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerSessionId\": \"{{customer_session_id}}\",\n  \"content\": \"Hello, I'm interested in your products\",\n  \"customerName\": \"John Doe\",\n  \"customerEmail\": \"john@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/chat/{{session_id}}/message",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "chat", "{{session_id}}", "message"]
            }
          }
        },
        {
          "name": "Get Chat History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/chat/{{session_id}}/history?customerSessionId={{customer_session_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "chat", "{{session_id}}", "history"],
              "query": [
                {
                  "key": "customerSessionId",
                  "value": "{{customer_session_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "End Chat Session",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/chat/{{session_id}}/end?customerSessionId={{customer_session_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "chat", "{{session_id}}", "end"],
              "query": [
                {
                  "key": "customerSessionId",
                  "value": "{{customer_session_id}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Get All Leads",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/leads",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "leads"]
            }
          }
        },
        {
          "name": "Get Leads by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/leads/status/NEW",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "leads", "status", "NEW"]
            }
          }
        },
        {
          "name": "Update Lead Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONTACTED\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/leads/{{lead_id}}/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "leads", "{{lead_id}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "Business",
      "item": [
        {
          "name": "Get Business Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/business/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "business", "profile"]
            }
          }
        },
        {
          "name": "Update Business Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agentSystemPrompt\": \"You are a friendly AI assistant for our company. Help customers with their questions.\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/business/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "business", "profile"]
            }
          }
        },
        {
          "name": "Get Business Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/business/sessions",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "business", "sessions"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "your-jwt-token-here"
    },
    {
      "key": "session_id",
      "value": "1"
    },
    {
      "key": "customer_session_id",
      "value": "your-customer-session-id"
    },
    {
      "key": "lead_id",
      "value": "1"
    }
  ]
}
